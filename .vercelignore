dashboard/node_modules/

# Build outputs (rebuilt on Vercel)
dist/
dashboard/dist/

# Environment files
.env
.env.local
dashboard/.env.local
backend/.env

# Development files
.venv/
venv/
__pycache__/
*.pyc

# IDE
.vscode/
.idea/

