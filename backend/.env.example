# Supabase — required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Data provider
DATA_PROVIDER=yfinance

# CORS — comma-separated origins for production
# e.g. https://nabeeh.vercel.app,https://nabeeh.com
FRONTEND_URL=http://localhost:5173

# AI Assistant — required (DeepSeek via OpenRouter)
# Get a free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Email Alerts (Resend) — optional, skipped if empty
RESEND_API_KEY=
ALERT_FROM_EMAIL=Nabeeh <onboarding@resend.dev>
FRONTEND_BASE_URL=http://localhost:5173

# Alert gating — minimum |risk_score_delta| to send an email.
# Sub-threshold updates still write to the DB but skip the email.
ALERT_MIN_SCORE_DELTA=5

# Scheduler (set false to disable cron jobs in dev)
SCHEDULER_ENABLED=true

# App
DEBUG=false
