{
  "buildCommand": "bash scripts/build.sh",
  "outputDirectory": "dist",
  "installCommand": "cd dashboard && npm ci",
  "framework": null,
  "functions": {
    "api/**/*.py": {
      "runtime": "@vercel/python@4.3.1"
    }
  },
  "rewrites": [
    { "source": "/api/v1/prices/market/tasi", "destination": "/api/tasi" },
    { "source": "/api/v1/assistant/chat", "destination": "/api/chat" },
    { "source": "/api/v1/assistant/health", "destination": "/api/health" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
